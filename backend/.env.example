# Salin file ini menjadi .env dan isi nilainya
# Di Railway: masukkan via Environment Variables di dashboard

PORT=3000
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
FONNTE_TOKEN=your_fonnte_token_here
META_ACCESS_TOKEN=EAAGxxxxxxxxxxxxxxxx
META_PHONE_NUMBER_ID=123456789012345
META_WABA_ID=987654321098765
META_VERIFY_TOKEN=my_verify_token_123
META_API_VERSION=v19.0
AI_SYSTEM_PROMPT=Kamu adalah CS AI yang ramah dan profesional untuk bisnis e-commerce Indonesia. Jawab pertanyaan produk, harga, stok, dan pengiriman. Tangani komplain dengan empati. Jika terlalu kompleks, sarankan bicara dengan agen manusia. Gunakan bahasa Indonesia yang sopan.

# URL frontend (untuk CORS) — isi setelah deploy ke Vercel
FRONTEND_URL=https://your-app.vercel.app
